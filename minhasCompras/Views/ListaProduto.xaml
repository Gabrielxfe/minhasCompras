<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="minhasCompras.Views.ListaProduto"
             Title="Minhas Compras">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1" />
        <ToolbarItem Text="Novo" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>

    <VerticalStackLayout Padding="10">
        <SearchBar x:Name="txt_procurar" SearchButtonPressed="SearchBar_SearchButtonPressed" Placeholder="Buscar produto..." />

        <ListView x:Name="lst_produtos" HasUnevenRows="True" ItemSelected="lst_produtos_ItemSelected">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <HorizontalStackLayout Spacing="15" Padding="10">
                            <VerticalStackLayout WidthRequest="200">
                                <Label Text="{Binding Descricao}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Total, StringFormat='Total: {0:C}'}" />
                            </VerticalStackLayout>

                            <ImageButton Source="delete.png" 
                                         VerticalOptions="Center"
                                         HeightRequest="30"
                                         CommandParameter="{Binding Id}"
                                         Clicked="ImageButton_Clicked" />
                        </HorizontalStackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </VerticalStackLayout>
</ContentPage>